# ==========================================
# KhoDeToán - Environment Variables
# ==========================================
# Copy file này thành .env.local và điền giá trị thực
# Nếu không cấu hình gì → ứng dụng chạy ở chế độ Demo (localStorage)

# ==========================================
# Database: Neon Postgres (KHUYÊN DÙNG - 50GB miễn phí)
# ==========================================
# Đăng ký tại: https://console.neon.tech
# Copy connection string từ Dashboard
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# JWT Secret cho Auth (tự tạo chuỗi ngẫu nhiên, ít nhất 32 ký tự)
JWT_SECRET=your-secret-key-at-least-32-chars

# ==========================================
# (Tùy chọn) Supabase - Dùng nếu KHÔNG cấu hình Neon
# ==========================================
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ==========================================
# Cloudinary (upload ảnh - unsigned mode)
# ==========================================
# Đăng ký tại: https://cloudinary.com
# Tạo Upload Preset: Settings → Upload → Add upload preset → Signing Mode: Unsigned
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=khodetoan_unsigned

# API Key & Secret (tùy chọn, chỉ cần cho signed upload nâng cao)
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# ==========================================
# Multi-account Cloudinary (tùy chọn - thêm dung lượng)
# ==========================================
# Mỗi tài khoản thêm = +25 credits (~25GB miễn phí)
# CLOUDINARY_CLOUD_NAME_2=
# CLOUDINARY_CLOUD_NAME_3=
