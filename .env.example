# ==========================================
# KhoDeToán - Environment Variables
# ==========================================
# Copy file này thành .env.local và điền giá trị thực
# Nếu không cấu hình Supabase → ứng dụng chạy ở chế độ Demo (localStorage)

# ==========================================
# Supabase (bắt buộc cho production)
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ==========================================
# Cloudinary (upload ảnh - unsigned mode)
# ==========================================
# Đăng ký tại: https://cloudinary.com
# Tạo Upload Preset: Settings → Upload → Add upload preset → Signing Mode: Unsigned
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=khodetoan_unsigned

# API Key & Secret (tùy chọn, chỉ cần cho signed upload nâng cao)
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ==========================================
# Multi-account Cloudinary (tùy chọn)
# ==========================================
# Mỗi tài khoản thêm = +25 credits (~25GB miễn phí)
# Tạo thêm tài khoản bằng email khác tại cloudinary.com
# CLOUDINARY_CLOUD_NAME_2=
# CLOUDINARY_API_KEY_2=
# CLOUDINARY_API_SECRET_2=
# CLOUDINARY_CLOUD_NAME_3=
# CLOUDINARY_API_KEY_3=
# CLOUDINARY_API_SECRET_3=

# ==========================================
# Tương lai: Neon Postgres (thay thế Supabase khi cần scale)
# ==========================================
# Khi migrate sang Neon (50GB free), bật flag này:
# DATABASE_PROVIDER=neon
# DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
